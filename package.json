{
  "name": "web-scrapper",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "install:browsers": "npx playwright install chromium",
    "knowledge": "npm run build && node --no-warnings --enable-source-maps dist/knowledge/index.js",
    "scrape": "npm run build && node --no-warnings --enable-source-maps dist/scraper/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.7.3",
    "@playwright/test": "^1.54.2",
    "sqlite-vec": "^0.1.7"
  },
  "devDependencies": {
    "@types/node": "^24.0.10",
    "typescript": "^5.9.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
